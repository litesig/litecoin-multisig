<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>LitecoinMultisig</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="src/Types.fs" />
    <Compile Include="src/Crypto.fs" />
    <Compile Include="src/Bip32.fs" />
